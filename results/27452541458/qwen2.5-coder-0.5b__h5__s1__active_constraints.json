      "final_file": "import json\nimport sys\nfrom pathlib import Path\nDATA_PATH = Path(\"todos.json\")\ndef load_items(path=DATA_PATH):\n    if not path.exists():\n        return []\n    return json.loads(path.read_text())\ndef save_items(items, path=DATA_PATH):\n    path.write_text(json.dumps(items, indent=2))\ndef next_id(items):\n    return 1 if not items else max(item[\"id\"] for item in items) + 1\ndef add_item(text, path=DATA_PATH):\n    items = load_items(path)\n    item = {\"id\": next_id(items), \"text\": text, \"done\": False, \"completed_at\": None}\n    items.append(item); save_items(items, path); return item\ndef list_items(path=DATA_PATH):\n    return load_items(path)\ndef mark_done(item_id, timestamp, path=DATA_PATH):\n    items = load_items(path)\n    for item in items:\n        if item[\"id\"] == item_id:\n            if not item[\"done\"]:\n                item[\"done\"] = True; item[\"completed_at\"] = timestamp\n            break\n    save_items(items, path); return items\ndef delete_item(item_id, path=DATA_PATH):\n    items = [item for item in load_items(path) if item[\"id\"] != item_id]\n    save_items(items, path); return items\ndef main(argv):\n    if len(argv) < 2: raise SystemExit(\"usage: todo.py add|list|done|delete ...\")\n    cmd = argv[1]\n    if cmd == \"add\": add_item(\" \".join(argv[2:]))\n    elif cmd == \"list\":\n        for item in list_items(): print(f'{item[\"id\"]}. [{\"x\" if item[\"done\"] else \" \"}] {item[\"text\"]}')\n    elif cmd == \"done\": mark_done(int(argv[2]), argv[3])\n    elif cmd == \"delete\": delete_item(int(argv[2]))\n    else: raise SystemExit(f\"unknown command: {cmd}\")\nif __name__ == \"__main__\": main(sys.argv)\n"
