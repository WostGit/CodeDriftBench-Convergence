  "final_todo_py": "import json\nimport sys\nfrom pathlib import Path\n\nDATA_PATH = Path(\"todos.json\")\n\ndef load_items(path=DATA_PATH):\n    if not path.exists():\n        return []\n    return json.loads(path.read_text())\n\ndef save_items(items, path=DATA_PATH):\n    path.write_text(json.dumps(items, indent=2))\n\ndef next_id(items):\n    if not items:\n        return 1\n    return max(item[\"id\"] for item in items) + 1\n\ndef add_item(text, path=DATA_PATH):\n    items = load_items(path)\n    item = {\"id\": next_id(items), \"text\": text, \"done\": False, \"completed_at\": None}\n    items.append(item)\n    save_items(items, path)\n    return item\n\ndef list_items(path=DATA_PATH):\n    return load_items(path)\n\ndef mark_done(item_id, timestamp, path=DATA_PATH):\n    items = load_items(path)\n    for item in items:\n        if item[\"id\"] == item_id:\n            if not item[\"done\"]:\n                item[\"done\"] = True\n                item[\"completed_at\"] = timestamp\n            break\n    save_items(items, path)\n    return items\n\ndef delete_item(item_id, path=DATA_PATH):\n    items = [item for item in load_items(path) if item[\"id\"] != item_id]\n    save_items(items, path)\n    return items\n\ndef main(argv):\n    if len(argv) < 2:\n        raise SystemExit(\"usage: todo.py add|list|done|delete ...\")\n    cmd = argv[1]\n    if cmd == \"add\":\n        add_item(\" \".join(argv[2:]))\n    elif cmd == \"list\":\n        for item in list_items():\n            status = \"x\" if item[\"done\"] else \" \"\n            print(f'{item[\"id\"]}. [{status}] {item[\"text\"]}')\n    elif cmd == \"done\":\n        mark_done(int(argv[2]), argv[3])\n    elif cmd == \"delete\":\n        delete_item(int(argv[2]))\n    else:\n        raise SystemExit(f\"unknown command: {cmd}\")\n\nif __name__ == \"__main__\":\n    main(sys.argv)\n",
